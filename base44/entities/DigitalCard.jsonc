    },
    "is_published": {
      "type": "boolean",
      "default": true,
      "description": "\u05d4\u05d0\u05dd \u05d4\u05db\u05e8\u05d8\u05d9\u05e1 \u05e4\u05d5\u05e8\u05e1\u05dd"
    }
  },
  "required": [
    "slug",
    "full_name"
  ],
  "rls": {
    "create": true,
    "read": true,
    "update": true,
    "delete": true

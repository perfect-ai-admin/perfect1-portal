      "type": "string",
      "description": "\u05db\u05ea\u05d5\u05d1\u05ea \u05d0\u05ea\u05e8"
    },
    "instagram_url": {
      "type": "string",
      "description": "\u05dc\u05d9\u05e0\u05e7 \u05d0\u05d9\u05e0\u05e1\u05d8\u05d2\u05e8\u05dd"
    },
    "facebook_url": {
      "type": "string",

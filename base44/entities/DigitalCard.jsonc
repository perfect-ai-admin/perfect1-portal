    },
    "linkedin_url": {
      "type": "string",
      "description": "\u05dc\u05d9\u05e0\u05e7 \u05dc\u05d9\u05e0\u05e7\u05d3\u05d0\u05d9\u05df"
    },
    "tiktok_url": {
      "type": "string",
      "description": "\u05dc\u05d9\u05e0\u05e7 \u05d8\u05d9\u05e7\u05d8\u05d5\u05e7"
    },
    "waze_url": {
      "type": "string",
      "description": "\u05dc\u05d9\u05e0\u05e7 Waze"
    },
    "logo_url": {
      "type": "string",
      "description": "URL \u05e9\u05dc \u05dc\u05d5\u05d2\u05d5 / \u05ea\u05de\u05d5\u05e0\u05ea \u05e4\u05e8\u05d5\u05e4\u05d9\u05dc"
    },
    "cover_image_url": {
      "type": "string",
      "description": "URL \u05e9\u05dc \u05ea\u05de\u05d5\u05e0\u05ea \u05e7\u05d0\u05d1\u05e8"
    },
    "qr_image_url": {
      "type": "string",
      "description": "URL \u05e9\u05dc \u05ea\u05de\u05d5\u05e0\u05ea QR"
    },
    "vcf_url": {
      "type": "string",

    {
      "id": "prepare-ai-prompt",
      "name": "Prepare AI Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1760, 80],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const allItems = $input.all();\n\n// Find competitor data item\nlet competitorTopics = [];\nlet competitorSummary = '';\nlet ourPages = [];\n\nfor (const item of allItems) {\n  if (item.json.all_topics) {\n    competitorTopics = item.json.all_topics || [];\n    competitorSummary = item.json.competitor_summary || '';\n  }\n  if (Array.isArray(item.json)) {\n    ourPages = item.json.map(p => p.page_url || p.title || '').filter(Boolean);\n  } else if (item.json.page_url) {\n    ourPages.push(item.json.page_url);\n  }\n}\n\nconst topicsStr = competitorTopics.slice(0, 60).join('\\n');\nconst ourStr = ourPages.slice(0, 50).join('\\n');\n\nconst prompt = `You are an Israeli SEO expert for perfect1.co.il, a business portal for Israeli small businesses and freelancers.\n\nCompetitor sites and their page counts:\n${competitorSummary}\n\nCompetitor topics/pages (sample):\n${topicsStr}\n\nOur existing content pages:\n${ourStr}\n\nIdentify 5 article gaps — topics competitors cover that we DON'T have yet, and that are relevant for Israeli small business owners (עוסק פטור, עוסק מורשה, חברה בע\"מ, מיסים, חשבוניות, ביטוח לאומי).\n\nReturn ONLY a JSON array with exactly 5 objects:\n[\n  {\n    \"title\": \"Hebrew article title\",\n    \"topic\": \"main keyword in Hebrew\",\n    \"competitor\": \"which competitor has this\",\n    \"why\": \"why it matters for our audience\"\n  }\n]`;\n\nreturn [{ json: { prompt, competitor_summary: competitorSummary, topic_count: competitorTopics.length } }];"
      }
    },
    {
      "id": "openai-gap-analysis",
      "name": "OpenAI - Gap Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1980, 80],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "specifyHeaders": "keypair",
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer {{ $credentials.openAiApi.apiKey }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify($json.prompt) }}\n    }\n  ],\n  \"temperature\": 0.7,\n  \"max_tokens\": 1000,\n  \"response_format\": { \"type\": \"json_object\" }\n}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi"
      },
      "credentials": {
        "openAiApi": {
          "id": "enLroXreMPFDnrNF",
          "name": "OpenAi account"
        }
      }
    },
    {
      "id": "parse-ai-response",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2200, 80],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const allItems = $input.all();\nconst response = allItems[0]?.json;\n\nlet ideas = [];\ntry {\n  const content = response.choices?.[0]?.message?.content || '{}';\n  const parsed = JSON.parse(content);\n  // Handle both array and object with array property\n  ideas = Array.isArray(parsed) ? parsed : (parsed.ideas || parsed.articles || Object.values(parsed)[0] || []);\n} catch(e) {\n  console.log('Parse error:', e.message);\n  ideas = [];\n}\n\nif (!Array.isArray(ideas) || ideas.length === 0) {\n  return [{ json: { title: 'No gaps found', topic: '', competitor: '', why: '' } }];\n}\n\nreturn ideas.slice(0, 5).map(idea => ({ json: idea }));"
      }
    },

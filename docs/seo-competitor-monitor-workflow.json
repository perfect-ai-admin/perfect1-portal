      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const competitors = [\n  'invoice4u.co.il',\n  'greeninvoice.co.il',\n  'ucan2.co.il',\n  'tax-advisor.co.il'\n];\nreturn competitors.map(c => ({ json: { competitor: c } }));"

      "id": "build-whatsapp-message",
      "name": "Build WhatsApp Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2640, 80],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const allItems = $input.all();\nconst ideas = allItems.map(i => i.json).filter(i => i.title && i.title !== 'No gaps found');\n\nconst today = new Date().toLocaleDateString('he-IL');\nlet msg = `*SEO - Competitor Monitor ${today}*\\n`;\nmsg += `נמצאו ${ideas.length} פערים מול המתחרים:\\n\\n`;\n\nideas.forEach((idea, i) => {\n  msg += `${i+1}. *${idea.title || ''}*\\n`;\n  if (idea.competitor) msg += `   מקור: ${idea.competitor}\\n`;\n  if (idea.why) msg += `   ${idea.why}\\n`;\n  msg += '\\n';\n});\n\nmsg += `_נוסף ל-seo_content_ideas וסו_opportunities_`;\n\nreturn [{ json: { message: msg, ideas_count: ideas.length } }];"
      }

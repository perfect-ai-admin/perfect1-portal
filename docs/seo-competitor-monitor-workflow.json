    },
    {
      "id": "fetch-sitemap",
      "name": "Fetch Competitor Sitemap",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 0],
      "parameters": {
        "method": "GET",
        "url": "=https://{{ $json.competitor }}/sitemap.xml",
        "options": {
          "response": {
            "response": {
              "fullResponse": false,
              "responseFormat": "text"
            }
          },
          "timeout": 10000
        }
      },
      "continueOnFail": true
    },
    {
      "id": "extract-urls",
      "name": "Extract URLs from Sitemap",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 0],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const competitor = $input.item.json.competitor || '';\nconst body = $input.item.json.data || $input.item.json.body || $input.item.json || '';\nconst bodyStr = typeof body === 'string' ? body : JSON.stringify(body);\n\n// Extract URLs from XML\nconst urlMatches = bodyStr.match(/<loc>([^<]+)<\\/loc>/g) || [];\nconst urls = urlMatches\n  .map(m => m.replace('<loc>', '').replace('</loc>', '').trim())\n  .filter(u => u.includes(competitor))\n  .filter(u => !u.endsWith('.xml') && !u.endsWith('/'))\n  .slice(0, 200);\n\n// Extract slugs/topics from URLs\nconst topics = urls.map(u => {\n  try {\n    const path = new URL(u).pathname;\n    return path.replace(/\\//g, ' ').trim().replace(/-/g, ' ');\n  } catch(e) { return u; }\n}).filter(Boolean);\n\nreturn [{ json: { competitor, url_count: urls.length, urls: urls.slice(0, 50), topics: topics.slice(0, 50) } }];"
      }
    },
    {
      "id": "aggregate-competitors",
      "name": "Aggregate All Competitors",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 0],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const allItems = $input.all();\nconst competitorData = allItems.map(i => i.json).filter(d => d.competitor);\n\nconst allTopics = [];\nconst competitorSummary = [];\n\nfor (const cd of competitorData) {\n  allTopics.push(...(cd.topics || []));\n  competitorSummary.push(`${cd.competitor}: ${cd.url_count} pages`);\n}\n\n// Deduplicate topics\nconst uniqueTopics = [...new Set(allTopics)].slice(0, 100);\n\nreturn [{ json: {\n  competitor_summary: competitorSummary.join('\\n'),\n  all_topics: uniqueTopics,\n  competitor_data: competitorData\n} }];"
      }
    },
    {
      "id": "our-content",

      "name": "GSC Page+Query Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 0],
      "parameters": {
        "method": "POST",
        "url": "https://searchconsole.googleapis.com/webmasters/v3/sites/https%3A%2F%2Fwww.perfect1.co.il%2F/searchAnalytics/query",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [

        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"startDate\": \"{{ $now.minus({days: 30}).toFormat('yyyy-MM-dd') }}\",\n  \"endDate\": \"{{ $now.minus({days: 2}).toFormat('yyyy-MM-dd') }}\",\n  \"dimensions\": [\"page\", \"query\"],\n  \"rowLimit\": 5000,\n  \"dataState\": \"final\"\n}"
      }
    },
    {
      "id": "detect-cannibalization",
      "name": "Detect Cannibalization",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 0],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rows = $input.first().json.rows || [];\n\n// Group by query\nconst queryPages = {};\nfor (const row of rows) {\n  const query = row.keys[1];\n  const page = row.keys[0];\n  if (!queryPages[query]) queryPages[query] = [];\n  queryPages[query].push({\n    page,\n    clicks: row.clicks || 0,\n    impressions: row.impressions || 0,\n    position: row.position || 100\n  });\n}\n\n// Find cannibalized queries (2+ pages, at least one with 5+ impressions)\nconst cannibalized = [];\nfor (const [query, pages] of Object.entries(queryPages)) {\n  if (pages.length >= 2 && pages.some(p => p.impressions >= 5)) {\n    const totalImpressions = pages.reduce((s, p) => s + p.impressions, 0);\n    const totalClicks = pages.reduce((s, p) => s + p.clicks, 0);\n    cannibalized.push({\n      query,\n      pages: pages.sort((a, b) => a.position - b.position),\n      page_count: pages.length,\n      total_impressions: totalImpressions,\n      total_clicks: totalClicks,\n      severity: pages.length >= 3 ? 'high' : 'medium'\n    });\n  }\n}\n\n// Sort by total impressions desc, take top 20\ncannibalized.sort((a, b) => b.total_impressions - a.total_impressions);\nconst top20 = cannibalized.slice(0, 20);\n\nif (top20.length === 0) {\n  return [{ json: { query: '__no_results__', pages: [], total_impressions: 0, total_clicks: 0, severity: 'none', page_count: 0 } }];\n}\n\nreturn top20.map(c => ({ json: c }));"
      }
    },
    {

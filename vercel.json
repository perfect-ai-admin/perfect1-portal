    { "source": "/hevra-bam/:slug", "destination": "/hevra-bam/:slug/index.html" },
    { "source": "/sgirat-tikim", "destination": "/sgirat-tikim/index.html" },
    { "source": "/sgirat-tikim/:slug", "destination": "/sgirat-tikim/:slug/index.html" },
    { "source": "/guides", "destination": "/guides/index.html" },
    { "source": "/guides/:slug", "destination": "/guides/:slug/index.html" },
    { "source": "/compare/:slug", "destination": "/compare/:slug/index.html" },
    { "source": "/patur-vs-murshe", "destination": "/index.html" },
    { "source": "/patur-vs-murshe-quiz", "destination": "/index.html" },
    { "source": "/OsekPaturLanding", "destination": "/index.html" },
    { "source": "/OsekPaturSteps", "destination": "/index.html" },
